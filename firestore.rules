rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.:@]+$');
    }

    function isOwner(userId) {
      return userId == request.auth.uid || 
             (request.auth.token != null && request.auth.token.email != null && userId == request.auth.token.email);
    }

    function isValidDocument(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.rows is list && data.rows.size() <= 5000 &&
             data.headers is list && data.headers.size() <= 50;
    }

    function isValidSettings(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             (data.blueText == null || (data.blueText is string && data.blueText.size() <= 100000)) &&
             (data.secretList == null || (data.secretList is list && data.secretList.size() <= 1000));
    }

    // Documents match block
    match /documents/{documentId} {
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || documentId == 'test');
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || 
                    (request.auth.token != null && request.auth.token.email != null && resource.data.userId == request.auth.token.email));
      
      allow create: if isSignedIn() && 
                       isValidId(documentId) && 
                       isValidDocument(request.resource.data) && 
                       isOwner(request.resource.data.userId);
                       
      allow update: if isSignedIn() && 
                       isValidId(documentId) && 
                       isValidDocument(request.resource.data) && 
                       isOwner(resource.data.userId) && 
                       isOwner(request.resource.data.userId);
                       
      allow delete: if isSignedIn() && 
                       isOwner(resource.data.userId);
    }

    // Settings match block
    match /settings/{settingsId} {
      allow get: if isSignedIn() && (isOwner(settingsId) || (resource != null && isOwner(resource.data.userId)));
      
      allow create, update: if isSignedIn() && 
                               isValidId(settingsId) && 
                               isValidSettings(request.resource.data) && 
                               isOwner(request.resource.data.userId) &&
                               isOwner(settingsId);
                               
      allow delete: if isSignedIn() && 
                       (isOwner(settingsId) || (resource != null && isOwner(resource.data.userId)));
    }
  }
}
